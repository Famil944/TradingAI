# Safe default: Binance Futures Demo/Testnet, never live.
TRADING_MODE=DEMO
TELEGRAM_BOT_TOKEN=
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Live trading remains blocked unless both credentials and the exact
# confirmation phrase below are supplied.
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=
LIVE_TRADING_CONFIRMATION=

# Emergency mode: blocks new entries but still allows protection and closing.
TRADING_CLOSE_ONLY=true

# Optional absolute SQLite location.
TRADING_AI_DB_PATH=

# Optional persistent file used by the Telegram Demo/Live selector.
# On Render set it to /var/data/trading_mode.
TRADING_MODE_STATE_PATH=
